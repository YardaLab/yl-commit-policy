{
  "name": "yl-tooling",
  "version": "0.1.0",
  "description": "YardaLab developer tooling CLI",
  "bin": {
    "yl-tooling": "./bin/yl-tooling.js"
  },
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ./scripts/copy-default-policy.mjs",
    "typecheck": "tsc -p tsconfig.dev.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "yardalab",
    "cli",
    "tooling"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "kleur": "^4.1.5",
    "tsx": "^4.21.0"
  }
}
