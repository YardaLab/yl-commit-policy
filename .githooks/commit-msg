#!/usr/bin/env sh
set -eu

COMMIT_MSG_FILE="$1"
REPO_ROOT="$(git rev-parse --show-toplevel)"

DIST_CLI="$REPO_ROOT/yl-tooling-npx/dist/cli.js"
SRC_CLI="$REPO_ROOT/yl-tooling-npx/src/cli.ts"

if [ -f "$DIST_CLI" ]; then
  node "$DIST_CLI" validate-commit "$COMMIT_MSG_FILE"
elif [ -f "$SRC_CLI" ]; then
  npx tsx "$SRC_CLI" validate-commit "$COMMIT_MSG_FILE"
else
  echo "❌ CLI not found (dist nor src)" >&2
  exit 1
fi