#!/usr/bin/env sh
set -eu

COMMIT_MSG_FILE="$1"

# resolve repo root (important for subdirs / git worktrees)
REPO_ROOT="$(git rev-parse --show-toplevel)"

# path to local CLI
CLI="$REPO_ROOT/yl-tooling-npx/src/index.ts"

# safety check
if [ ! -f "$CLI" ]; then
  echo "❌ Validator not found at $CLI" >&2
  exit 1
fi

# run validator via tsx
if ! npx tsx "$CLI" commit-check "$COMMIT_MSG_FILE"; then
  echo "❌ Commit message validation failed" >&2
  exit 1
fi

exit 0